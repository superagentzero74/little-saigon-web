rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // User avatars
    match /users/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Business photos
    match /businesses/{businessId}/photos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Dish hero images
    match /foods/{rank}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default fallback
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
