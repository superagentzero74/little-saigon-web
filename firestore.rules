rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /businesses/{id} {
      allow read: if true;
      allow write: if isAdmin();

      match /photos/{photoId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if isAdmin();
      }
    }

    match /reviews/{id} {
      allow read: if true;
      // Doc ID must be {businessId}_{userId} — enforces one review per user per business
      allow create: if request.auth != null &&
        id == (request.resource.data.businessId + "_" + request.auth.uid);
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /users/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());
    }

    match /picks/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /foods/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /checkIns/{id} {
      allow read, write: if request.auth != null;
    }

    match /checkins/{id} {
      allow read, write: if request.auth != null;
    }

    match /pointsLog/{id} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }

    match /redemptions/{id} {
      allow read, write: if request.auth != null;
    }

    match /dishFeatured/{dishRank} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subcategories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promoBanners/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /claimRequests/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isAdmin();
    }
  }
}
